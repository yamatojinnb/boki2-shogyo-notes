---
import { getCollection, render } from 'astro:content';
import LessonLayout from '../../layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const lessons = (await getCollection('lessons')).sort((a, b) => a.data.order - b.data.order);
  return lessons.map((lesson, i) => ({
    params: { slug: lesson.id },
    props: { lesson, prev: lessons[i - 1], next: lessons[i + 1] },
  }));
}

const { lesson, prev, next } = Astro.props;
const { Content } = await render(lesson);
---

<LessonLayout lesson={lesson} prev={prev} next={next}>
  <Content />
</LessonLayout>
